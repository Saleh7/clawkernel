# Gateway connection (copy to .env and fill in)
# Find your token in: ~/.openclaw/openclaw.json → gateway.token
VITE_GATEWAY_URL=ws://localhost:18789
VITE_GATEWAY_TOKEN=your-gateway-token-here

# OpenClaw home directory (default: ~/.openclaw)
# Change this if OpenClaw is installed in a non-standard location.
# Affects workspace path suggestions in the UI only — actual paths come from the Gateway.
VITE_OPENCLAW_HOME=~/.openclaw
